// Pins
const int pinS1 = 2;    // Encoder S1 (Interrupt)
const int pinS2 = 4;    // Encoder S2 (Direction)
const int motorL = 5;   // IN1
const int motorR = 6;   // IN2

// Constants
const int pulsesPerRevolution = 40; 

// Variables
volatile int pulseCount = 0;
float rotations = 0.0;
float current_deg = 0.0;
float target_deg = 360.0; 

void setup() {
  pinMode(pinS1, INPUT_PULLUP);
  pinMode(pinS2, INPUT_PULLUP);
  pinMode(motorL, OUTPUT);
  pinMode(motorR, OUTPUT);

  attachInterrupt(digitalPinToInterrupt(pinS1), handleEncoder, CHANGE);

  Serial.begin(9600);
}

void loop() {
  // 1. Calculate Position
  rotations = (float)pulseCount / (float)pulsesPerRevolution;
  current_deg = rotations * 360.0;

  // 2. Continuous Hunting Logic (No ENA/PWM)
  // We use a tiny deadzone (2 degrees) so it doesn't vibrate 
  // quite as violently, but it will still be "jumpy".
  
  if (current_deg < (target_deg - 2.0)) {
    // Too low? Full power forward
    digitalWrite(motorL, HIGH);
    digitalWrite(motorR, LOW);
  } 
  else if (current_deg > (target_deg + 2.0)) {
    // Too high? Full power backward
    digitalWrite(motorL, LOW);
    digitalWrite(motorR, HIGH);
  } 
  else {
    // Within 2 degrees? Coast/Stop
    digitalWrite(motorL, LOW);
    digitalWrite(motorR, LOW);
  }

  // Serial Monitor
  static unsigned long lastPrint = 0;
  if (millis() - lastPrint > 50) {
    // Labeling values (optional, only in IDE 2.0+)
    Serial.print("Current:"); 
    Serial.print(current_deg);
    Serial.print(",");
    Serial.print("Target:"); 
    Serial.println(target_deg); // Ends the line to plot the point
    
    lastPrint = millis();
  }
}

void handleEncoder() {
  if (digitalRead(pinS1) != digitalRead(pinS2)) {
    pulseCount++;
  } else {
    pulseCount--;
  }
}
